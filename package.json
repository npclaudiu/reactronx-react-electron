{
    "name": "reactronx-monorepo",
    "version": "0.0.0",
    "private": true,
    "description": "Monorepo for React-backed Electron reconciler resources",
    "workspaces": [
        "packages/*"
    ],
    "engines": {
        "node": ">=20.0.0",
        "pnpm": ">=10.0.0"
    },
    "packageManager": "pnpm@10.30.3",
    "author": "Claudiu Nedelcu",
    "license": "BSD-2-Clause",
    "repository": {
        "type": "git",
        "url": "https://github.com/npclaudiu/reactronx.git"
    },
    "scripts": {
        "build": "pnpm -r run build",
        "lint": "pnpm -r run lint",
        "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
        "typecheck": "tsc -b",
        "test:integration": "pnpm -r --filter \"./packages/**\" run build && pnpm --dir tests/integration/app run build && playwright test"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@playwright/test": "^1.58.2",
        "@types/node": "^25.3.3",
        "@typescript-eslint/eslint-plugin": "^8.56.1",
        "@typescript-eslint/parser": "^8.56.1",
        "eslint": "^10.0.2",
        "globals": "^17.4.0",
        "prettier": "^3.2.5",
        "typescript": "^5.3.3",
        "typescript-eslint": "^8.56.1"
    },
    "dependencies": {
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "react": "^19.2.4",
        "react-dom": "^19.2.4"
    }
}
