        "typescript": "^5.3.3"
    },
    "peerDependencies": {
        "typescript": ">=5.3.3"
    },
    "peerDependenciesMeta": {
        "typescript": {
            "optional": true
        }
    },
    "devDependencies": {
        "@types/node": "^25.3.3"
    },
