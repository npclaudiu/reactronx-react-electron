{
    "name": "reactronx",
    "version": "0.1.0",
    "description": "CLI for building Electron apps powered by Reactronx",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "bin": {
        "reactronx": "dist/bin.js"
    },
    "files": [
        "dist"
    ],
    "scripts": {
